{% extends ['base.html.twig', 'layout.twig.html'] %}

{% block title %}Hello DefaultController!{% endblock %}

{% block body %}
    {% block header %}
        <h1>Nous Contacter</h1>
    {% endblock %}

    {% block content %}
        <p>Nous sommes actuellement le : {{ 'now'|format_datetime('full', 'full', locale='fr') }}</p>
    {% endblock %}

        {{ form_start(form) }}
        {{ form_row(form.email) }}
        {{ form_row(form.subject) }}
        {{ form_row(form.message) }}

        {{ form_rest(form) }}
        <button type="submit" class="btn btn-primary">Valider</button>
    {{ form_end(form) }}

{% endblock %}